# Bittlebits MCP server configuration.
#
# The recommended way to connect is `npx bittlebits-mcp setup`, which signs you
# in through the browser and writes these values into your client config for you.
# The variables below are only needed if you prefer to configure things by hand.

# Your Bittlebits API key. If unset, running the server in a terminal opens a
# browser to sign in and caches the key at ~/.bittlebits/config.json.
# BITTLEBITS_API_KEY=your_api_key_here

# Optional: point the server and setup flow at a non-production instance.
# BITTLEBITS_BASE_URL=https://bittlebits.ai
